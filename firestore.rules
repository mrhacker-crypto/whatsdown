rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Rules
    match /users/{userCode} {
      allow read, write: if true;
    }

    // Conversation Rules
    match /conversations/{conversationId} {
      allow read, write: if true;
      
      // Messages Subcollection Rules
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}

